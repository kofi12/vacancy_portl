// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  role         Role          @default(RP)
  fullName     String
  email        String        @unique
  phone        String?
  authProvider String?
  authSubject  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  org          Organization?
  applicants   Applicant[]
  applications Application[]
}

model Organization {
  id        String   @id @default(uuid())
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rcfs      Rcf[]
}

model Rcf {
  id              String        @id @default(uuid())
  org             Organization  @relation(fields: [orgId], references: [id])
  orgId           String
  name            String
  licensedBeds    Int
  currentOpenings Int
  isActive        Boolean
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  rcfForms        RcfForm[]
  applications    Application[]
}

model RcfForm {
  id          String       @id @default(uuid())
  rcf         Rcf          @relation(fields: [rcfId], references: [id])
  rcfId       String
  fileName    String
  title       String
  formType    TemplateType @default(CUSTOM)
  contentType ContentType  @default(PDF)
  storageKey  String
}

model Applicant {
  id          String        @id @default(uuid())
  rp          User          @relation(fields: [rpId], references: [id])
  rpId        String
  name        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Application {
  id                  String                @id @default(uuid())
  rcf                 Rcf                   @relation(fields: [rcfId], references: [id])
  rcfId               String
  applicant           Applicant             @relation(fields: [applicantId], references: [id])
  applicantId         String
  rp                  User                  @relation(fields: [rpId], references: [id])
  rpId                String
  status              Status
  submittedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  applicationDocument ApplicationDocument[]
}

model ApplicationDocument {
  id               String       @id @default(uuid())
  application      Application  @relation(fields: [applicationId], references: [id])
  applicationId    String
  type             TemplateType
  originalFileName String
  contentType      ContentType
  storageKey       String
}

enum Role {
  OWNER
  RP
  ADMIN
}

enum TemplateType {
  INTAKE_FORM
  SCHEDULE_20
  CUSTOM
}

enum ContentType {
  PDF
  JSON
  ZIP
  MULTIPART
}

enum Status {
  SUBMITTED
  PENDING
}
